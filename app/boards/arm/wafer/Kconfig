config BOARD_WAFER_LEFT
    select SOC_NRF52840_QIAA
    imply RETAINED_MEM
    imply RETENTION
    imply RETENTION_BOOT_MODE
    help
      Enable support for the Wafer board using the nRF52840 SoC.

config BOARD_WAFER_RIGHT
    select SOC_NRF52840_QIAA
    imply RETAINED_MEM
    imply RETENTION
    imply RETENTION_BOOT_MODE
